ARG FZF_VERSION=0.72.0
ARG RG_VERSION=15.1.0
ARG GH_VERSION=2.92.0
ARG YQ_VERSION=4.53.3
ARG GO_VERSION=1.26.2
ARG OPENCODE_VERSION=1.14.29
ARG CRUSH_VERSION=0.65.3
ARG PYTHON_VERSION=3.14.4
ARG PYTHON_BUILD=20260414
ARG JIRA_MCP_VERSION=0.1.0
ARG GOPLS_VERSION=0.21.1
ARG PYRIGHT_VERSION=1.1.409

# ---- Stage 1: Base tools (shared by all agents) ----
FROM registry.access.redhat.com/ubi10/nodejs-24 AS base-tools
ARG FZF_VERSION
ARG RG_VERSION
ARG GH_VERSION
ARG YQ_VERSION

# The base image ends with a non-root USER; reclaim root for setup
USER root

# UBI does not provide a "node" user; create one to match the node:20-slim convention
RUN groupadd -g 1000 node && useradd -u 1000 -g node -m -s /bin/bash node

# OpenShell Supervisor requires a 'sandbox' user and group in every agent image
RUN groupadd sandbox && useradd -g sandbox -m -s /bin/bash sandbox

RUN dnf install -y \
    git curl ca-certificates zsh vim-minimal nano less jq openssh-clients sudo openssl \
    && dnf clean all \
    && echo "node ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/node \
    && chmod 0440 /etc/sudoers.d/node

RUN set -ex; \
    ARCH_RAW=$(uname -m); \
    case "$ARCH_RAW" in \
      x86_64)  ARCH_SHORT=amd64 ;; \
      aarch64) ARCH_SHORT=arm64 ;; \
      *) echo "Unsupported arch: $ARCH_RAW" >&2 && exit 1 ;; \
    esac; \
    curl -fsSL "https://github.com/junegunn/fzf/releases/download/v${FZF_VERSION}/fzf-${FZF_VERSION}-linux_${ARCH_SHORT}.tar.gz" \
        | tar -xz -C /usr/local/bin fzf; \
    chmod +x /usr/local/bin/fzf; \
    fzf --version

RUN set -ex; \
    ARCH_RAW=$(uname -m); \
    curl -fsSL "https://github.com/BurntSushi/ripgrep/releases/download/${RG_VERSION}/ripgrep-${RG_VERSION}-${ARCH_RAW}-unknown-linux-musl.tar.gz" \
        | tar -xz -C /usr/local/bin --strip-components=1 \
              "ripgrep-${RG_VERSION}-${ARCH_RAW}-unknown-linux-musl/rg"; \
    chmod +x /usr/local/bin/rg; \
    rg --version

RUN set -ex; \
    ARCH_RAW=$(uname -m); \
    case "$ARCH_RAW" in \
      x86_64)  ARCH_SHORT=amd64 ;; \
      aarch64) ARCH_SHORT=arm64 ;; \
      *) echo "Unsupported arch: $ARCH_RAW" >&2 && exit 1 ;; \
    esac; \
    curl -fsSL "https://github.com/cli/cli/releases/download/v${GH_VERSION}/gh_${GH_VERSION}_linux_${ARCH_SHORT}.tar.gz" \
        | tar -xz -C /usr/local/bin --strip-components=2 "gh_${GH_VERSION}_linux_${ARCH_SHORT}/bin/gh"; \
    chmod +x /usr/local/bin/gh; \
    gh --version

RUN set -ex; \
    ARCH_RAW=$(uname -m); \
    case "$ARCH_RAW" in \
      x86_64)  ARCH_SHORT=amd64 ;; \
      aarch64) ARCH_SHORT=arm64 ;; \
      *) echo "Unsupported arch: $ARCH_RAW" >&2 && exit 1 ;; \
    esac; \
    YQ_ASSET="yq_linux_${ARCH_SHORT}"; \
    YQ_URL="https://github.com/mikefarah/yq/releases/download/v${YQ_VERSION}"; \
    cd /tmp; \
    curl -fsSL "${YQ_URL}/checksums" -o checksums; \
    curl -fsSL "${YQ_URL}/checksums_hashes_order" -o checksums_hashes_order; \
    curl -fsSL "${YQ_URL}/extract-checksum.sh" -o extract-checksum.sh; \
    chmod +x extract-checksum.sh; \
    ./extract-checksum.sh SHA-256 "${YQ_ASSET}" | awk '{ print $2 " " $1 }' > checksum.sha256; \
    curl -fsSL "${YQ_URL}/${YQ_ASSET}" -o "${YQ_ASSET}"; \
    sha256sum -c checksum.sha256; \
    install -m 0755 "${YQ_ASSET}" /usr/local/bin/yq; \
    rm -f checksums checksums_hashes_order extract-checksum.sh checksum.sha256 "${YQ_ASSET}"; \
    yq --version

# npm global prefix under /usr/local/share, owned by the non-root "node" user
RUN mkdir -p /usr/local/share/npm-global \
    && chown -R node:node /usr/local/share/npm-global \
    && mkdir -p /sandbox \
    && chown sandbox:sandbox /sandbox
ENV NPM_CONFIG_PREFIX=/usr/local/share/npm-global
ENV NPM_CONFIG_CACHE=/home/node/.npm
ENV PATH=$PATH:/usr/local/share/npm-global/bin

USER node
WORKDIR /sandbox

ENV DEVCONTAINER=true
ENV EDITOR=nano
ENV NODE_OPTIONS=--max-old-space-size=1536


# ---- Stage 2: Runtime languages (Go + Python, shared by all agents) ----
FROM base-tools AS base-runtimes
ARG GO_VERSION
ARG PYTHON_VERSION
ARG PYTHON_BUILD
ARG GOPLS_VERSION
ARG PYRIGHT_VERSION
USER root

RUN set -ex; \
    ARCH_RAW=$(uname -m); \
    case "$ARCH_RAW" in \
      x86_64)  ARCH_SHORT=amd64 ;; \
      aarch64) ARCH_SHORT=arm64 ;; \
      *) echo "Unsupported arch: $ARCH_RAW" >&2 && exit 1 ;; \
    esac; \
    curl -fsSL "https://dl.google.com/go/go${GO_VERSION}.linux-${ARCH_SHORT}.tar.gz" \
        | tar -xz -C /usr/local; \
    /usr/local/go/bin/go version
ENV PATH=$PATH:/usr/local/go/bin
ENV GOPATH=/home/node/go

RUN set -ex; \
    ARCH_RAW=$(uname -m); \
    case "$ARCH_RAW" in \
      x86_64)  PY_ARCH=x86_64 ;; \
      aarch64) PY_ARCH=aarch64 ;; \
      *) echo "Unsupported arch: $ARCH_RAW" >&2 && exit 1 ;; \
    esac; \
    curl -fsSL "https://github.com/indygreg/python-build-standalone/releases/download/${PYTHON_BUILD}/cpython-${PYTHON_VERSION}+${PYTHON_BUILD}-${PY_ARCH}-unknown-linux-gnu-install_only.tar.gz" \
        | tar -xz -C /usr/local --strip-components=1; \
    python3 --version

# Install Jira MCP Server from GitHub Releases
ARG JIRA_MCP_VERSION
RUN set -ex; \
    curl -fsSL -o /tmp/jira_mcp_server-${JIRA_MCP_VERSION}-py3-none-any.whl \
        "https://github.com/stolostron/jira-mcp-server/releases/download/v${JIRA_MCP_VERSION}/jira_mcp_server-${JIRA_MCP_VERSION}-py3-none-any.whl" \
    && python3 -m ensurepip --upgrade \
    && python3 -m pip install --no-cache-dir /tmp/jira_mcp_server-*.whl \
    && rm -f /tmp/jira_mcp_server-*.whl \
    && jira-mcp-server --help | head -5

# Install LSP servers (gopls for Go, pyright for Python) — versions pinned via ARGs
RUN /usr/local/go/bin/go install golang.org/x/tools/gopls@v${GOPLS_VERSION}
ENV PATH=$PATH:/home/node/go/bin
RUN python3 -m pip install --no-cache-dir pyright==${PYRIGHT_VERSION}

# GitHub App auth — transparent gh/git when credentials are mounted at runtime.
# Upstream: server-foundation-agent/build/scripts (kubeopencode/devbox pattern).
# Mount /etc/github-app/{client_id,installation_id,private_key} or set GH_APP_* env.
COPY --chmod=755 scripts/github-app/github-app-iat.sh /usr/local/bin/
COPY --chmod=755 scripts/github-app/github-token-manager.sh /usr/local/bin/
COPY --chmod=755 scripts/github-app/gh-wrapper.sh /usr/local/bin/
COPY --chmod=755 scripts/github-app/git-credential-github-app.sh /usr/local/bin/
RUN mv /usr/local/bin/gh /usr/bin/gh-real \
    && ln -sf /usr/local/bin/gh-wrapper.sh /usr/local/bin/gh \
    && git config --system credential.helper /usr/local/bin/git-credential-github-app.sh

USER node

# ---- Stage 3a: Crush agent ----
FROM base-runtimes AS crush
ARG CRUSH_VERSION

USER root
RUN set -ex; \
    ARCH_RAW=$(uname -m); \
    case "$ARCH_RAW" in \
      x86_64)  CRUSH_ARCH=x86_64 ;; \
      aarch64) CRUSH_ARCH=arm64 ;; \
      *) echo "Unsupported arch: $ARCH_RAW" >&2 && exit 1 ;; \
    esac; \
    FILENAME="crush_${CRUSH_VERSION}_Linux_${CRUSH_ARCH}.tar.gz"; \
    URL="https://github.com/charmbracelet/crush/releases/download/v${CRUSH_VERSION}/${FILENAME}"; \
    echo "Downloading Crush v${CRUSH_VERSION} for ${CRUSH_ARCH}..."; \
    curl --retry 5 --retry-delay 3 --retry-all-errors -fsSL "${URL}" \
        | tar -xz --strip-components=1 -C /usr/local/bin \
            "crush_${CRUSH_VERSION}_Linux_${CRUSH_ARCH}/crush"; \
    chmod +x /usr/local/bin/crush; \
    crush --version

USER root

# Crush config — written to sandbox home where Crush resolves ${HOME}/.config/crush/
RUN mkdir -p /home/sandbox/.config/crush \
    && chown -R sandbox:sandbox /home/sandbox/.config
COPY --chown=sandbox:sandbox containerfiles/crush.json /home/sandbox/.config/crush/crush.json

USER node

# GCP credentials path for Claude via Vertex AI — value injected at runtime
ENV GOOGLE_APPLICATION_CREDENTIALS=/app/gcloud/credentials.json
ENV CRUSH_DISABLE_METRICS=1
ENV DO_NOT_TRACK=1

CMD ["crush"]

# ---- Stage 3b: OpenCode agent (last stage — default for OpenShift builds) ----
FROM base-runtimes AS opencode
ARG OPENCODE_VERSION

USER node
RUN npm install -g opencode-ai@${OPENCODE_VERSION} --ignore-scripts && \
    OC_DIR=/usr/local/share/npm-global/lib/node_modules/opencode-ai && \
    cd "$OC_DIR" && npm install --ignore-scripts opencode-linux-x64@${OPENCODE_VERSION} && \
    cp "$OC_DIR/node_modules/opencode-linux-x64/bin/opencode" /usr/local/share/npm-global/bin/opencode && \
    chmod 755 /usr/local/share/npm-global/bin/opencode && \
    npm cache clean --force

# Provider config: restrict to Claude (Vertex) and Gemini only.
# Credentials are injected at runtime via K8s/Podman secrets.
COPY --chown=sandbox:sandbox containerfiles/opencode.json /sandbox/opencode.json

# GCP credentials path for Claude via Vertex AI — value injected at runtime
ENV GOOGLE_APPLICATION_CREDENTIALS=/app/gcloud/credentials.json

CMD ["opencode"]
